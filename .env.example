TELEGRAM_TOKEN=            # from @BotFather
OPENAI_API_KEY=           # from platform.openai.com
OWNER_CHAT_ID=            # your Telegram numeric chat id (bot only talks to you)
OWNER_TZ=Asia/Kolkata     # your local timezone for all scheduling
MODEL=gpt-5-mini          # conversation model (quality)
GATE_MODEL=gpt-5-nano     # cheap "reach out now?" decision
MAX_SILENCE_HOURS=24      # safety floor
HISTORY_WINDOW=30         # recent turns loaded per call
DEBOUNCE_SECONDS=3        # batch your rapid messages
PRESENCE_WINDOW_MIN=5     # don't proactively text if you just talked
REFLECTION_HOUR=3         # nightly reflection at 3am local
GIF_PROVIDER=tenor        # stickers/gifs — tenor | giphy | (empty = disabled)
GIF_API_KEY=              # provider key; if empty, send_gif is disabled
